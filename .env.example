# Local / override examples — never commit real secrets
NODE_ENV=development
PORT=3847
DATA_DIR=./data

# Required in production (Render). Stable secret — rotating it makes existing files undecryptable.
# MASTER_KEY=

# Your https://….onrender.com URL (no trailing slash)
# PUBLIC_URL=

# First platform admin (must match a registered user email)
# BOOTSTRAP_ADMIN_EMAIL=you@example.com

# Optional SSO (local register/login always works for non-org users)
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

SESSION_DAYS=7
MAX_UPLOAD_BYTES=52428800
